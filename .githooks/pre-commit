#!/usr/bin/env bash
# capiba-zed — pre-commit hook
# Ativa com: git config core.hooksPath .githooks
set -euo pipefail

VERDE='\033[0;32m'
VERMELHO='\033[0;31m'
RESET='\033[0m'

ok()   { echo -e "${VERDE}✓${RESET} $*"; }
erro() { echo -e "${VERMELHO}✗${RESET} $*"; exit 1; }

echo "▶ capiba pre-commit"

# Formataçao
cargo fmt --check 2>/dev/null \
  && ok "fmt" \
  || erro "fmt — rode 'cargo fmt' antes de commitar"

# Lint
cargo clippy -p capiba-prompts -p capiba-mcp -- -D warnings 2>/dev/null \
  && ok "clippy" \
  || erro "clippy — corrija os warnings antes de commitar"

# Testes com cobertura (mínimo 89%)
# Os ~11% restantes são stubs do ServerHandler (list_resources, read_resource,
# list_prompts, get_prompt) e main() — requerem RequestContext<rmcp::RoleServer>,
# tipo opaco do SDK sem constructor público. Cobertos apenas em integration tests.
COBERTURA_MIN=89

if ! command -v cargo-llvm-cov &>/dev/null; then
  erro "cargo-llvm-cov não encontrado — instale com: cargo binstall cargo-llvm-cov (ver. declarada em [workspace.metadata.tools])"
fi

RESUMO=$(cargo llvm-cov -p capiba-mcp --summary-only 2>/dev/null) \
  || erro "testes falharam — veja o output acima"

COBERTURA=$(echo "$RESUMO" | awk '/^TOTAL/{gsub(/%/,"",$10); print int($10)}')

if [[ -z "$COBERTURA" ]]; then
  erro "cobertura — não foi possível calcular a cobertura de linhas"
fi

if [[ "$COBERTURA" -lt "$COBERTURA_MIN" ]]; then
  erro "cobertura insuficiente: ${COBERTURA}% (mínimo ${COBERTURA_MIN}%)"
fi

ok "testes e cobertura: ${COBERTURA}%"

echo "✓ pronto para commitar"
